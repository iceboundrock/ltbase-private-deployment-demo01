{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Visit",
  "description": "Lead property visit (showing) record",
  "type": "object",
  "$defs": {
    "visit_id": {
      "type": "string",
      "description": "Visit identifier",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "format": "uuid"
    }
  },
  "required": [
    "id",
    "leadId",
    "userId",
    "propertyId",
    "scheduledStartAt",
    "status"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/visit_id"
    },
    "leadId": {
      "$ref": "lead.json#/$defs/lead_id"
    },
    "contactSnapshot": {
      "$ref": "lead.json#/$defs/contact",
      "x-relation": {
        "key_property": "leadId"
      }
    },
    "userId": {
      "type": "string",
      "description": "Agent conducting the visit"
    },
    "propertyId": {
      "type": "string",
      "description": "Property being visited"
    },
    "propertySnapshot": {
      "type": "object",
      "description": "Optional property snapshot to preserve historical info",
      "properties": {
        "code": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "price": {
          "type": "number",
          "minimum": 0
        },
        "rent": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "scheduledStartAt": {
      "type": "string",
      "format": "date-time",
      "description": "Scheduled start time"
    },
    "scheduledEndAt": {
      "type": "string",
      "format": "date-time",
      "description": "Scheduled end time"
    },
    "status": {
      "type": "string",
      "enum": [
        "scheduled",
        "visited",
        "no_show",
        "canceled",
        "rescheduled"
      ],
      "description": "Visit status"
    },
    "actualStartAt": {
      "type": "string",
      "format": "date-time",
      "description": "Actual start time"
    },
    "actualEndAt": {
      "type": "string",
      "format": "date-time",
      "description": "Actual end time"
    },
    "feedback": {
      "type": "string",
      "description": "Client feedback or notes from the visit"
    },
    "attendees": {
      "type": "array",
      "description": "List of attendees (names or user IDs)",
      "items": {
        "type": "string"
      }
    },
    "nextFollowUpAt": {
      "type": "string",
      "format": "date-time",
      "description": "Next follow-up time derived from the visit"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "createdBy": {
      "type": "string",
      "description": "User ID of who created the visit record"
    },
    "updatedBy": {
      "type": "string",
      "description": "User ID of who last updated the visit record"
    },
    "deletedBy": {
      "type": "string",
      "description": "User ID of who deleted the visit record"
    },
    "ownerTeam": {
      "type": "string",
      "description": "Team that owns the visit record"
    }
  }
}
