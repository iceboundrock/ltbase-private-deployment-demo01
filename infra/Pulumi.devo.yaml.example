config:
  ltbase-infra:awsRegion: ap-northeast-1
  ltbase-infra:runtimeBucket: customer-ltbase-runtime-devo
  ltbase-infra:tableName: customer-ltbase-devo
  ltbase-infra:apiDomain: api.devo.customer.example.com
  ltbase-infra:controlPlaneDomain: control.devo.customer.example.com
  ltbase-infra:authDomain: auth.devo.customer.example.com
  ltbase-infra:projectId: 11111111-1111-4111-8111-111111111111
  ltbase-infra:authProviderConfigFile: infra/auth-providers.devo.json
  ltbase-infra:cloudflareZoneId: replace-with-zone-id
  ltbase-infra:oidcIssuerUrl: https://oidc.ltbase.dev/customer-devo
  ltbase-infra:jwksUrl: https://oidc.ltbase.dev/customer-devo/.well-known/jwks.json
  ltbase-infra:githubOrg: customer-org
  ltbase-infra:githubRepo: ltbase-private-deployment
  ltbase-infra:manageGithubOidcProvider: "true"
  ltbase-infra:formaCdcSchedule: rate(15 minutes)
  ltbase-infra:releaseId: v1.0.0
  ltbase-infra:dsqlPort: "5432"
  ltbase-infra:dsqlDB: postgres
  ltbase-infra:dsqlUser: admin
  ltbase-infra:dsqlProjectSchema: ltbase
  ltbase-infra:geminiModel: gemini-3-flash-preview
