config:
  ltbase-infra:awsRegion: us-west-2
  ltbase-infra:deploymentAwsAccountId: "210987654321"
  ltbase-infra:runtimeBucket: customer-ltbase-runtime-prod
  ltbase-infra:schemaBucket: customer-ltbase-schema-prod
  ltbase-infra:tableName: customer-ltbase-prod
  ltbase-infra:mtlsTruststoreFile: infra/certs/cloudflare-origin-pull-ca.pem
  ltbase-infra:mtlsTruststoreKey: mtls/cloudflare-origin-pull-ca.pem
  ltbase-infra:apiDomain: api.customer.example.com
  ltbase-infra:controlPlaneDomain: control.customer.example.com
  ltbase-infra:controlPlaneCorsOrigins: https://admin.customer.example.com
  ltbase-infra:authDomain: auth.customer.example.com
  ltbase-infra:projectId: 22222222-2222-4222-8222-222222222222
  ltbase-infra:authProviderConfigFile: infra/auth-providers.prod.json
  ltbase-infra:firebaseApiKey:
    secure: replace-with-firebase-api-key-secret
  ltbase-infra:firebaseProjectId: replace-with-firebase-project-id
  ltbase-infra:supabaseUrl: https://replace-with-project.supabase.co
  ltbase-infra:supabaseAnonKey: replace-with-supabase-anon-key
  ltbase-infra:cloudflareZoneId: replace-with-zone-id
  ltbase-infra:oidcIssuerUrl: https://oidc.ltbase.dev/customer-prod
  ltbase-infra:jwksUrl: https://oidc.ltbase.dev/customer-prod/.well-known/jwks.json
  ltbase-infra:releaseId: v1.0.0
  ltbase-infra:githubOrg: customer-org
  ltbase-infra:githubRepo: ltbase-private-deployment
  ltbase-infra:manageGithubOidcProvider: "false"
  ltbase-infra:githubOidcProviderArn: replace-with-prod-provider-arn
  ltbase-infra:geminiApiKey:
    secure: replace-with-gemini-api-key-secret
  ltbase-infra:geminiModel: gemini-3.1-flash-lite
  ltbase-infra:dsqlPort: "5432"
  ltbase-infra:dsqlDB: postgres
  ltbase-infra:dsqlUser: admin
  ltbase-infra:dsqlProjectSchema: ltbase
  ltbase-infra:formaCdcSchedule: rate(15 minutes)
